    {
      "id": "line_02",
      "speaker": "オレンジ髪の少女",
      "text": "えっ、それって\n新作のケーキ3個分\nくらいだよ！？",
      "panelIndex": 1,
      "bubblePosition": "left",
      "durationInFrames": 103,
      "audioFile": "voiceover/session_1778852121522/line_02.wav"
    },
    {
      "id": "line_03",
      "speaker": "褐色の金髪少女",
      "text": "月1万で『生活犠牲』とか、\nギャグのセンス古すぎっしょ！",
      "panelIndex": 1,
      "bubblePosition": "right",
      "durationInFrames": 135,
      "audioFile": "voiceover/session_1778852121522/line_03.wav"
    },
    {
      "id": "line_04",
      "speaker": "ツインテメガネの少女",
      "text": "……サエコさん、\n今のフィギュア、\n1体3万円するんだよ。",
      "panelIndex": 2,
      "bubblePosition": "left",
      "durationInFrames": 135,
      "audioFile": "voiceover/session_1778852121522/line_04.wav"
    },
    {
      "id": "line_05",
      "speaker": "黒髪の少女",
      "text": "1万円もあれば\n学食が何食食べられると……！\n没収に値する不健全な金額です！",
      "panelIndex": 2,
      "bubblePosition": "right",
      "durationInFrames": 158,
      "audioFile": "voiceover/session_1778852121522/line_05.wav"
    },
    {
      "id": "line_06",
      "speaker": "黒髪の少女",
      "text": "1万円なんて、\nただの『端数』じゃん！！",
      "panelIndex": 3,
      "bubblePosition": "right",
      "durationInFrames": 100,
